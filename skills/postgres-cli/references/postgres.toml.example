config_version = 2
default_target = "local-read"
# Global default search_path for all connections.
# Array form maps to: SET search_path TO "bellimmo", "public";
schema = ["bellimmo", "public"]
# Tables to prioritize in schema-cache mode (`schema-cache update`).
# Use schema-qualified names to avoid ambiguity.
important_tables = ["bellimmo.clients", "bellimmo.orders", "public.audit_log"]
statement_timeout_ms = 30000
connect_timeout_s = 10
# Optional override. If omitted, postgres-cli resolves `psql` from PATH.
# psql_bin = "/absolute/path/to/psql"

[schema_cache]
# default: tables/<table>.json
file_naming = "table"
# file_naming = "schema_table" # tables/<schema>.<table>.json

[connections.local-read]
host = "127.0.0.1"
port = 5432
database = "app"
username = "app"
password_env = "PGPASSWORD_APP"
application_name = "codex-agent"
sslmode = "prefer"
# Optional per-connection override. If set, this is used instead of top-level `schema`.
schema = ["bellimmo", "public"]
allow_write = false

[connections.local-write]
host = "127.0.0.1"
port = 5432
database = "app"
username = "app"
password_env = "PGPASSWORD_APP"
application_name = "codex-agent"
sslmode = "prefer"
allow_write = true

# Optional DSN-based target using env var (preferred over plaintext):
# [connections.remote-read]
# dsn_env = "DATABASE_URL_REMOTE"
# allow_write = false
